# Copy to .env (or export in your shell) and adjust as needed

# JWT
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database (SQLite file by default; use sqlite:///:memory: for in-memory)
DATABASE_URL=sqlite:///./monitoring.db

# LLM API (optional — the /diagnosis endpoint falls back to a rule-based
# diagnosis when no key is configured)
ANTHROPIC_API_KEY=
